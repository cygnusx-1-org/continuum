<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/endpoint_item_api_statistics_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:fontFamily="monospace"
        tools:text="/r/{sub}/{sort}" />

    <ml.docilealligator.infinityforreddit.customviews.BarChartView
        android:id="@+id/chart_item_api_statistics_row"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/detail_item_api_statistics_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textSize="12sp"
        tools:text="n: 15m 2 · 1h 10 · 1d 120 · 1w 400 · ttfb 210 ms · max 1.2 s · 1 err" />

</LinearLayout>
