    <dimen name="nav_header_vertical_spacing">8dp</dimen>
    <dimen name="nav_header_height">176dp</dimen>
    <dimen name="fab_margin">16dp</dimen>
    <!-- Bottom clearance so the last list item can scroll clear of a bottom|end FAB
         (FAB 56dp + fab_margin 16dp + 16dp breathing room). -->
    <dimen name="fab_clearance">88dp</dimen>
    <dimen name="roundedBottomSheetCornerRadiusLeftPadding">0dp</dimen>
    <dimen name="roundedBottomSheetCornerRadiusRightPadding">0dp</dimen>
    <dimen name="staggeredLayoutManagerItemOffset">16dp</dimen>
    <dimen name="mtrl_slider_track_side_padding">2dp</dimen>
    <!-- Square thumbnail box in the compact/card-2 post layouts. Read by both the layouts and
         PostRecyclerViewAdapter so the picked Reddit preview resolution matches the rendered
         size at the device's density (override per screen-size qualifier if ever needed). -->
    <dimen name="post_compact_thumbnail_size">112dp</dimen>
</resources>